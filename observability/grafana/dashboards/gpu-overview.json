{
  "dashboard": {
    "title": "Hopper - GPU Overview",
    "uid": "hopper-gpu-overview",
    "tags": ["hopper", "gpu"],
    "timezone": "browser",
    "panels": [
      {
        "title": "GPU Utilization",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "DCGM_FI_DEV_GPU_UTIL",
            "legendFormat": "{{ gpu }} - {{ instance }}"
          }
        ]
      },
      {
        "title": "GPU Temperature",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "DCGM_FI_DEV_GPU_TEMP",
            "legendFormat": "{{ gpu }} - {{ instance }}"
          }
        ]
      },
      {
        "title": "GPU Memory Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "DCGM_FI_DEV_FB_USED / (DCGM_FI_DEV_FB_USED + DCGM_FI_DEV_FB_FREE) * 100",
            "legendFormat": "{{ gpu }} - {{ instance }}"
          }
        ]
      },
      {
        "title": "Active Student Pods",
        "type": "stat",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "count(kube_pod_status_phase{phase=\"Running\", namespace=~\"hopper-pod-.*\"})"
          }
        ]
      }
    ],
    "templating": {
      "list": []
    },
    "time": { "from": "now-1h", "to": "now" },
    "refresh": "30s"
  }
}
